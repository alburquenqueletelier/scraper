# ─── Stores ───────────────────────────────────────────────────────────────────
# Comma-separated. Supported: paris.cl, ripley.cl, falabella.com, entel.cl, clarochile.cl, lider.cl
STORE_URLS=https://www.paris.cl/,https://simple.ripley.cl/,https://www.falabella.com/falabella-cl/,https://www.lider.cl/,https://www.entel.cl/,https://www.clarochile.cl/personas/

# ─── Products ─────────────────────────────────────────────────────────────────
# Format: NombreProducto:PrecioMaximoCLP  (price optional)
# Multiple products separated by comma
PRODUCTS=iPhone 15:800000,Laptop Gaming:1200000,Silla Gamer:150000,Smart TV:400000

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openrouter | openai | cloudflare
LLM_PROVIDER=openrouter

# OpenRouter (free tier: https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudflare Workers AI (if LLM_PROVIDER=cloudflare)
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# ─── Timing ───────────────────────────────────────────────────────────────────
# Loop interval in milliseconds (default: 15 min)
LOOP_INTERVAL_MS=900000

# Max scrapers running in parallel
MAX_CONCURRENT=3

# Puppeteer navigation timeout in milliseconds
PUPPETEER_TIMEOUT=30000
